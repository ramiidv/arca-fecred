{
  "name": "@ramiidv/arca-fecred",
  "version": "0.1.0",
  "description": "TypeScript SDK para el web service WSFECRED de ARCA (ex AFIP) - Factura de Credito Electronica MiPyME",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "llms.txt",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "arca",
    "afip",
    "wsfecred",
    "fce",
    "factura-credito-electronica",
    "mipyme",
    "argentina",
    "sdk",
    "typescript",
    "soap"
  ],
  "author": "ramiidv",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ramiidv/arca-fecred.git"
  },
  "homepage": "https://arca-sdk.dev/fecred",
  "bugs": {
    "url": "https://github.com/ramiidv/arca-fecred/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@ramiidv/arca-common": "^0.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.4"
  }
}
